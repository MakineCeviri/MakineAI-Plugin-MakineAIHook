{
    "id": "com.makineceviri.makineaihook",
    "name": "MakineAI Hook",
    "version": "0.2.0",
    "apiVersion": 1,
    "category": "hook",
    "description": "Game text extraction via process hooking, asset parsing, and memory scanning",
    "author": "MakineAI Team",
    "license": "GPL-3.0",
    "homepage": "https://github.com/MakineCeviri/MakineAI-Plugin-MakineAIHook",
    "entry": "makineaihook.dll",
    "dependencies": [],
    "capabilities": ["process", "hook", "parser", "memory"],
    "features": [
        "GDI text hooking (TextOut, DrawText, ExtTextOut)",
        "GetGlyphOutline hooking",
        "Process injection (CreateRemoteThread)",
        "Named pipe IPC",
        "Auto text deduplication",
        "Unity AssetBundle/resources.assets parsing",
        "Unreal Engine PAK archive parsing",
        "Bethesda BA2 archive parsing",
        "GameMaker data.win parsing",
        "Engine auto-detection from game files",
        "Process memory scanning for Turkish text",
        "Encoding obfuscation detection"
    ],
    "platforms": ["win64"],
    "minLauncherVersion": "0.1.0",
    "settings": [
        {
            "key": "hookEnabled",
            "type": "toggle",
            "label": "Hook Aktif",
            "default": "false"
        },
        {
            "key": "targetProcess",
            "type": "text",
            "label": "Hedef İşlem",
            "default": ""
        },
        {
            "key": "hookFilter",
            "type": "select",
            "label": "Hook Filtresi",
            "options": ["all", "textout", "drawtext", "glyph"],
            "default": "all"
        },
        {
            "key": "minTextLength",
            "type": "select",
            "label": "Min Metin Uzunluğu",
            "options": ["1", "2", "3", "5", "10"],
            "default": "2"
        },
        {
            "key": "deduplication",
            "type": "toggle",
            "label": "Tekrar Filtresi",
            "default": "true"
        },
        {
            "key": "memoryScanning",
            "type": "toggle",
            "label": "Bellek Tarama",
            "default": "false"
        }
    ]
}
